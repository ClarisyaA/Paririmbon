    rdfs:comment "Objek dan alat buatan manusia."@id ;
    rdfs:subClassOf paririmbon:Entity .

paririmbon:Entity.Person a owl:Class ;
    rdfs:label "Orang"@id ;
    rdfs:comment "Individu manusia atau persona."@id ;
    rdfs:subClassOf paririmbon:Entity .

paririmbon:Manuscript_Carita_Parahiyangan a paririmbon:Manuscript ;
    rdfs:label "Carita Parahiyangan"@id ;
    paririmbon:creationPeriod "Akhir abad ke-15"^^xsd:string ;
    paririmbon:manuscriptTitle "Carita Parahiyangan"^^xsd:string .

paririmbon:W0012 a paririmbon:Attribute.MoralAttribute ;
    rdfs:label "abiwada"@su ;
    paririmbon:creationPeriod "Abad ke-16"^^xsd:string ;
    paririmbon:definition "sangat hormat"^^xsd:string ;
    paririmbon:entryID "W0012"^^xsd:string ;
    paririmbon:foundInManuscript paririmbon:Manuscript_Amanat_Galunggung ;
    paririmbon:isRelatedTo paririmbon:W0001 ;
    paririmbon:latinTerm "abiwada"^^xsd:string ;
    paririmbon:manuscriptTitle "Amanat Galunggung"^^xsd:string ;
    paririmbon:scriptTerm "ᮃᮘᮤᮝᮓ"^^xsd:string ;
    paririmbon:usageContext "Menunjukkan sikap hormat yang mendalam, biasanya dalam dialog dengan guru atau leluhur."^^xsd:string ;
    paririmbon:wordClass "Attribute.MoralAttribute"^^xsd:string .

paririmbon:Concept.LiteraryWork a owl:Class ;
    rdfs:label "Karya Sastra"@id ;
    rdfs:comment "Referensi ke karya sastra atau puitis dan genrenya."@id ;
    rdfs:subClassOf paririmbon:Concept .

paririmbon:Attribute.AestheticAttribute a owl:Class ;
    rdfs:label "Atribut Estetika"@id ;
    rdfs:comment "Atribut yang terkait dengan keindahan, seni, dan estetika."@id ;
    rdfs:subClassOf paririmbon:Attribute .

paririmbon:W0001 a paririmbon:Concept.ReligiousConcept ;
    rdfs:label "aba"@su ;
    paririmbon:creationPeriod "Abad ke-15"^^xsd:string ;
    paririmbon:definition "keindahan, gaya, suara, kata, perintah"^^xsd:string ;
    paririmbon:entryID "W0001"^^xsd:string ;
    paririmbon:foundInManuscript paririmbon:Manuscript_Sanghyang_Hayu ;
    paririmbon:isRelatedTo paririmbon:W1120 ;
    paririmbon:latinTerm "aba"^^xsd:string ;
    paririmbon:manuscriptTitle "Sanghyang Hayu"^^xsd:string ;
    paririmbon:scriptTerm "ᮃᮘ"^^xsd:string ;
    paririmbon:usageContext "Menyebut keindahan bunyi, gaya bahasa, atau keelapan kata dalam mantra dan pupuh."^^xsd:string ;
    paririmbon:wordClass "Concept.ReligiousConcept"^^xsd:string .

paririmbon:Concept.PhilosophicalConcept a owl:Class ;
    rdfs:label "Konsep Filosofis"@id ;
    rdfs:comment "Ide-ide filosofis dan epistemologis abstrak."@id ;
    rdfs:subClassOf paririmbon:Concept .

paririmbon:W0003 a paririmbon:Attribute.EmotionalAttribute ;
    rdfs:label "abi"@su ;
    paririmbon:creationPeriod "Sunda Kuno"^^xsd:string ;
    paririmbon:definition "lebih, sangat, keinginan yang sangat, keinginan yang lebih"^^xsd:string ;
    paririmbon:entryID "W0003"^^xsd:string ;
    paririmbon:foundInManuscript paririmbon:Manuscript_Kamus_Umum ;
    paririmbon:isRelatedTo paririmbon:W0001 ;
    paririmbon:latinTerm "abi"^^xsd:string ;
    paririmbon:manuscriptTitle "Kamus Umum"^^xsd:string ;
    paririmbon:scriptTerm "ᮃᮘᮤ"^^xsd:string ;
    paririmbon:usageContext "Dipakai sebagai awalan penguat untuk menyatakan kadar sangat, lebih, atau keinginan yang meluap."^^xsd:string ;
    paririmbon:wordClass "Attribute.EmotionalAttribute"^^xsd:string .

paririmbon:Manuscript_Kamus_Umum a paririmbon:Manuscript ;
