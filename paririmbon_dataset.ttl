paririmbon:creationPeriod a owl:DatatypeProperty ;
    rdfs:label "creationPeriod"@en ;
    rdfs:domain paririmbon:Manuscript,
        paririmbon:Word ;
    rdfs:range xsd:string .

paririmbon:definition a owl:DatatypeProperty ;
    rdfs:label "definition"@en ;
    rdfs:domain paririmbon:Word ;
    rdfs:range xsd:string .

paririmbon:entryID a owl:DatatypeProperty ;
    rdfs:label "entryID"@en ;
    rdfs:domain paririmbon:Word ;
    rdfs:range xsd:string .

paririmbon:foundInManuscript a owl:ObjectProperty ;
    rdfs:label "ditemukan dalam"@id ;
    rdfs:comment "Menghubungkan entri kosakata ke individu Manuscript."@id ;
    rdfs:domain paririmbon:Word ;
    rdfs:range paririmbon:Manuscript .

paririmbon:hasPart a owl:ObjectProperty ;
    rdfs:label "memiliki bagian"@id ;
    rdfs:domain paririmbon:Word ;
    rdfs:range paririmbon:Word ;
    owl:inverseOf paririmbon:isPartOf .

paririmbon:isDerivedFrom a owl:ObjectProperty ;
    rdfs:label "diturunkan dari"@id ;
    rdfs:comment "Menunjukkan derivasi morfologis atau etimologis."@id ;
    rdfs:domain paririmbon:Word ;
    rdfs:range paririmbon:Word .

paririmbon:isOppositeOf a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "lawan kata dari"@id ;
    rdfs:comment "Menunjukkan dua entri memiliki makna berlawanan (antonim)."@id ;
    rdfs:domain paririmbon:Word ;
    rdfs:range paririmbon:Word .

paririmbon:isRelatedTo a owl:ObjectProperty ;
    rdfs:label "berhubungan dengan"@id ;
    rdfs:comment "Hubungan semantik umum antara dua entri kosakata."@id ;
    rdfs:domain paririmbon:Word ;
    rdfs:range paririmbon:Word .

paririmbon:isSynonymOf a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "sinonim dari"@id ;
    rdfs:comment "Menunjukkan dua entri memiliki makna yang setara."@id ;
    rdfs:domain paririmbon:Word ;
    rdfs:range paririmbon:Word .

paririmbon:latinTerm a owl:DatatypeProperty ;
    rdfs:label "latinTerm"@en ;
    rdfs:domain paririmbon:Word ;
    rdfs:range xsd:string .

paririmbon:manuscriptTitle a owl:DatatypeProperty ;
    rdfs:label "manuscriptTitle"@en ;
    rdfs:domain paririmbon:Manuscript,
        paririmbon:Word ;
    rdfs:range xsd:string .

paririmbon:ontology a owl:Ontology ;
    rdfs:label "Ontologi Paririmbon"@id ;
    dcterms:created "2026-05-10"^^xsd:date ;
    dcterms:creator "Proyek Digitalisasi Paririmbon" ;
    rdfs:comment "Ontologi kosakata naskah kuno Sunda (Paririmbon) yang mencakup konsep, atribut, tindakan, dan entitas dalam tradisi intelektual Sunda."@id .

